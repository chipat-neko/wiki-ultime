# Star Citizen Companion - Variables d'environnement
# Copiez ce fichier en .env et remplissez vos clés API
# IMPORTANT : Ne jamais committer le fichier .env (il est dans .gitignore)

# ─── Supabase (auth + base de données + stockage images) ─────
# Récupérer ces valeurs dans : supabase.com → votre projet → Settings → API
VITE_SUPABASE_URL=https://VOTRE_ID.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGci...votre_cle_anon...

# ─── APIs externes (optionnel — fonctionnent sans clé pour certains endpoints) ─
VITE_UEXCORP_API_URL=https://uexcorp.space/api/2.0
VITE_UEXCORP_API_KEY=your_uexcorp_api_key_here

VITE_ERKUL_API_URL=https://www.erkul.games/api
VITE_ERKUL_API_KEY=your_erkul_api_key_here

VITE_SCTRADETOOLS_API_URL=https://sc-trade.tools/api

# ─── App ─────────────────────────────────────────────────────
VITE_APP_NAME=Star Citizen Companion
VITE_APP_VERSION=1.0.0
VITE_CACHE_TTL=300000
VITE_ENABLE_ANALYTICS=false
